#!/usr/bin/env bash

set -Eeuo pipefail

# setupWorkspace is stored in:
#   monutchee-manifest/zudemo/setupWorkspace
#
# The workspace defaults to the directory from which this script is run.
# Override it with:
#   ./setupWorkspace --workspace /path/to/KR260Demo all

WORKSPACE_ROOT="${PWD}"

MANIFEST_REPO_URL="${MANIFEST_REPO_URL:-https://github.com/lesterlo/monutchee-manifest.git}"
MANIFEST_BRANCH="${MANIFEST_BRANCH:-main}"
MANIFEST_FILE="${MANIFEST_FILE:-kr260demo/kr260demo.xml}"

# Product identity for this workspace. Recorded into yocto-build/.mncos-product
# so `source ./setupSDK` needs no --product argument in any new console.
MONUTCHEE_PRODUCT="${MONUTCHEE_PRODUCT:-kr260demo}"

APU_REPO_URL="${APU_REPO_URL:-git@github.com:lesterlo/KR260Demo_APU.git}"
RPU_REPO_URL="${RPU_REPO_URL:-git@github.com:lesterlo/KR260Demo_RPU.git}"
PL_REPO_URL="${PL_REPO_URL:-git@github.com:lesterlo/KR260Demo_PL.git}"

DO_YOCTO=false
DO_APU=false
DO_RPU=false
DO_PL=false

usage() {
    cat <<'EOF'
Usage:
  setupWorkspace [--workspace DIRECTORY] COMPONENT [COMPONENT...]

Components:
  all       Set up Yocto, APU, RPU, and PL
  yocto     Create yocto-build, run repo init, then repo sync

Note:
  Every run also (re)generates an "openTmux" launcher in the workspace
  root. Run ./openTmux to open a "zudemo" tmux session with windows for
  yocto-build, APU, RPU, PL, and the yocto tftpboot directory.
  apu       Clone or switch KR260Demo_APU to main
  rpu       Clone or switch KR260Demo_RPU to main
  pl        Clone or switch KR260Demo_PL to main

Examples:
  ./setupWorkspace --workspace ~/work/KR260Demo all
  ./setupWorkspace --workspace ~/work/KR260Demo yocto apu
  ./setupWorkspace pl rpu

Environment overrides:
  MANIFEST_REPO_URL
  MANIFEST_BRANCH
  MANIFEST_FILE
  APU_REPO_URL
  RPU_REPO_URL
  PL_REPO_URL
EOF
}

select_all() {
    DO_YOCTO=true
    DO_APU=true
    DO_RPU=true
    DO_PL=true
}

parse_arguments() {
    local selected=0

    while (($# > 0)); do
        case "$1" in
            --workspace)
                if (($# < 2)); then
                    printf 'Error: --workspace requires a directory.\n' >&2
                    exit 2
                fi

                WORKSPACE_ROOT="$2"
                shift 2
                ;;

            --workspace=*)
                WORKSPACE_ROOT="${1#*=}"
                shift
                ;;

            all|ALL|All)
                select_all
                selected=1
                shift
                ;;

            yocto|YOCTO|Yocto)
                DO_YOCTO=true
                selected=1
                shift
                ;;

            apu|APU)
                DO_APU=true
                selected=1
                shift
                ;;

            rpu|RPU)
                DO_RPU=true
                selected=1
                shift
                ;;

            pl|PL)
                DO_PL=true
                selected=1
                shift
                ;;

            -h|--help)
                usage
                exit 0
                ;;

            *)
                printf 'Error: unknown option or component: %s\n\n' "$1" >&2
                usage >&2
                exit 2
                ;;
        esac
    done

    if ((selected == 0)); then
        usage
        exit 2
    fi
}

resolve_manifest_repo_url() {
    local manifest_repo_root

    if [[ -n "${MANIFEST_REPO_URL}" ]]; then
        return
    fi

    manifest_repo_root="$(
        git -C "${SCRIPT_DIR}" rev-parse --show-toplevel 2>/dev/null || true
    )"

    if [[ -n "${manifest_repo_root}" ]]; then
        MANIFEST_REPO_URL="$(
            git -C "${manifest_repo_root}" remote get-url origin 2>/dev/null || true
        )"
    fi

    if [[ -z "${MANIFEST_REPO_URL}" ]]; then
        MANIFEST_REPO_URL="https://github.com/lesterlo/monutchee-manifest.git"
    fi
}

create_runtime_directories() {
    mkdir -p -- \
        "${WORKSPACE_ROOT}/runtime-generated/vivado_SDT_out" \
        "${WORKSPACE_ROOT}/runtime-generated/bin_file"

    printf 'Runtime directories are ready:\n'
    printf '  %s\n' "${WORKSPACE_ROOT}/runtime-generated/vivado_SDT_out"
    printf '  %s\n' "${WORKSPACE_ROOT}/runtime-generated/bin_file"
}

create_tmux_launcher() {
    local launcher="${WORKSPACE_ROOT}/openTmux"

    cat >"${launcher}" <<'EOF'
#!/usr/bin/env bash

set -Eeuo pipefail

# openTmux opens a "zudemo" tmux session with one window per component:
#   yocto  -> yocto-build
#   apu    -> KR260Demo_APU
#   rpu    -> KR260Demo_RPU
#   pl     -> KR260Demo_PL
#   tftp   -> yocto-build/build/export/tftpboot
#
# This file is generated by setupWorkspace. It locates the workspace from
# its own directory, so run it from wherever it lives in the workspace root.

SESSION="zudemo"

WORKSPACE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

if ! command -v tmux >/dev/null 2>&1; then
    printf 'Error: tmux was not found in PATH.\n' >&2
    exit 1
fi

# If the session already exists, just attach to (or switch to) it.
if tmux has-session -t "${SESSION}" 2>/dev/null; then
    printf 'Session %s already exists; attaching.\n' "${SESSION}"
    if [[ -n "${TMUX:-}" ]]; then
        exec tmux switch-client -t "${SESSION}"
    else
        exec tmux attach-session -t "${SESSION}"
    fi
fi

open_window() {
    # open_window <name> <directory>
    local name="$1"
    local dir="$2"

    if [[ ! -d "${dir}" ]]; then
        printf 'Warning: %s does not exist yet; opening %s in workspace root.\n' \
            "${dir}" "${name}" >&2
        dir="${WORKSPACE_ROOT}"
    fi

    if [[ -z "${SESSION_CREATED:-}" ]]; then
        tmux new-session -d -s "${SESSION}" -n "${name}" -c "${dir}"
        SESSION_CREATED=1
    else
        tmux new-window -t "${SESSION}:" -n "${name}" -c "${dir}"
    fi
}

open_window yocto "${WORKSPACE_ROOT}/yocto-build"

# Source the Yocto SDK environment in the yocto window.
if [[ -e "${WORKSPACE_ROOT}/yocto-build/setupSDK" ]]; then
    tmux send-keys -t "${SESSION}:yocto" 'source ./setupSDK' C-m
else
    printf 'Warning: yocto-build/setupSDK not found; skipping source.\n' >&2
fi

open_window apu   "${WORKSPACE_ROOT}/KR260Demo_APU"
open_window rpu   "${WORKSPACE_ROOT}/KR260Demo_RPU"
open_window pl    "${WORKSPACE_ROOT}/KR260Demo_PL"
open_window tftp  "${WORKSPACE_ROOT}/yocto-build/build/export/tftpboot"

# Start on the first window.
tmux select-window -t "${SESSION}:yocto"

if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "${SESSION}"
else
    exec tmux attach-session -t "${SESSION}"
fi
EOF

    chmod +x -- "${launcher}"

    printf 'tmux launcher is ready:\n'
    printf '  %s\n' "${launcher}"
}

clone_or_checkout_main() {
    local project_name="$1"
    local repo_url="$2"
    local destination="${WORKSPACE_ROOT}/${project_name}"

    if [[ ! -e "${destination}" ]]; then
        printf 'Cloning %s...\n' "${project_name}"

        if git clone \
            "${repo_url}" \
            "${destination}"; then

            printf 'Cloned %s on branch main.\n' "${project_name}"
            return 0
        fi

        printf 'Warning: failed to clone %s. The user may not have access.\n' \
            "${project_name}" >&2

        # Remove a partially created directory left by a failed clone.
        if [[ -e "${destination}" ]]; then
            rm -rf -- "${destination}"
        fi

        return 1
    fi

    if ! git -C "${destination}" rev-parse --is-inside-work-tree \
        >/dev/null 2>&1; then

        printf 'Error: destination exists but is not a Git repository:\n' >&2
        printf '  %s\n' "${destination}" >&2
        return 1
    fi

    if git -C "${destination}" show-ref \
        --verify --quiet refs/heads/main; then

        git -C "${destination}" switch main || return 1

    elif git -C "${destination}" show-ref \
        --verify --quiet refs/remotes/origin/main; then

        git -C "${destination}" switch --track origin/main || return 1

    else
        printf 'Error: %s has no local main or origin/main branch.\n' \
            "${project_name}" >&2
        return 1
    fi

    printf '%s is on branch main.\n' "${project_name}"
}

setup_yocto() {
    local yocto_dir="${WORKSPACE_ROOT}/yocto-build"

    if ! command -v repo >/dev/null 2>&1; then
        printf 'Error: repo command was not found in PATH.\n' >&2
        return 1
    fi

    if [[ -d "${yocto_dir}" && ! -d "${yocto_dir}/.repo" ]]; then
        if [[ -n "$(find "${yocto_dir}" -mindepth 1 -maxdepth 1 \
            -print -quit 2>/dev/null)" ]]; then

            printf 'Error: yocto-build exists, is non-empty, and is not a repo workspace:\n' >&2
            printf '  %s\n' "${yocto_dir}" >&2
            return 1
        fi
    fi

    mkdir -p -- "${yocto_dir}"

    printf 'Initializing Yocto workspace:\n'
    printf '  manifest repository: %s\n' "${MANIFEST_REPO_URL}"
    printf '  manifest branch:     %s\n' "${MANIFEST_BRANCH}"
    printf '  manifest file:       %s\n' "${MANIFEST_FILE}"
    printf '  destination:         %s\n' "${yocto_dir}"

    (
        cd "${yocto_dir}"

        repo init \
            -u "${MANIFEST_REPO_URL}" \
            -b "${MANIFEST_BRANCH}" \
            -m "${MANIFEST_FILE}" \
            || exit 1

        repo sync || exit 1
    ) || return 1

    # Record the product so `source ./setupSDK` works with no argument.
    printf '%s\n' "${MONUTCHEE_PRODUCT}" > "${yocto_dir}/.mncos-product"
    printf 'Recorded product marker: %s (%s)\n' \
        "${MONUTCHEE_PRODUCT}" "${yocto_dir}/.mncos-product"

    printf 'Yocto workspace synchronized successfully.\n'
}

main() {
    local failures=0

    parse_arguments "$@"
    resolve_manifest_repo_url

    mkdir -p -- "${WORKSPACE_ROOT}"
    WORKSPACE_ROOT="$(cd -- "${WORKSPACE_ROOT}" && pwd -P)"

    printf 'Workspace root: %s\n\n' "${WORKSPACE_ROOT}"

    create_runtime_directories
    printf '\n'

    create_tmux_launcher
    printf '\n'

    if [[ "${DO_YOCTO}" == true ]]; then
        setup_yocto || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_APU}" == true ]]; then
        clone_or_checkout_main "KR260Demo_APU" "${APU_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_RPU}" == true ]]; then
        clone_or_checkout_main "KR260Demo_RPU" "${RPU_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_PL}" == true ]]; then
        clone_or_checkout_main "KR260Demo_PL" "${PL_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if ((failures > 0)); then
        printf 'Workspace setup completed with %d failed component(s).\n' \
            "${failures}" >&2
        exit 1
    fi

    printf 'Workspace setup completed successfully.\n'
}

main "$@"
