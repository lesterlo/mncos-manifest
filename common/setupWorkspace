#!/usr/bin/env bash

set -Eeuo pipefail

# Shared Monutchee workspace setup (Option A: one product per workspace).
#
# Invoked by the per-product wrappers, which pass --product:
#   zudemo/zudemo-setupWorkspace       -> --product zudemo
#   kr260demo/kr260demo-setupWorkspace -> --product kr260demo
#
# Each run creates one product workspace containing:
#   yocto-build/         repo-managed Yocto source checkout (per-product manifest)
#   <Prefix>_APU/RPU/PL  product application / firmware / PL repositories
#   runtime-generated/   local generated handoff files
#   openTmux             generated tmux launcher
#
# The only per-product differences live in configure_product(); everything
# else is shared.

WORKSPACE_ROOT="${PWD}"

MANIFEST_REPO_URL="${MANIFEST_REPO_URL:-https://github.com/lesterlo/monutchee-manifest.git}"
MANIFEST_BRANCH="${MANIFEST_BRANCH:-main}"
MANIFEST_FILE="${MANIFEST_FILE:-}"
MONUTCHEE_PRODUCT="${MONUTCHEE_PRODUCT:-}"

YOCTO_DIR_NAME="${YOCTO_DIR_NAME:-yocto-build}"

# Per-product values; filled in by configure_product().
PROJECT_PREFIX=""
TMUX_SESSION=""
YOCTO_BUILD_DIR=""
APU_REPO_URL="${APU_REPO_URL:-}"
RPU_REPO_URL="${RPU_REPO_URL:-}"
PL_REPO_URL="${PL_REPO_URL:-}"

DO_YOCTO=false
DO_APU=false
DO_RPU=false
DO_PL=false

usage() {
    cat <<'EOF'
Usage:
  setupWorkspace --product PRODUCT [--workspace DIRECTORY] COMPONENT [COMPONENT...]

Products:
  zudemo       ZuBoard demo workspace
  kr260demo    KR260 demo workspace

Components:
  all       Set up Yocto, APU, RPU, and PL
  yocto     Create yocto-build, run repo init, then repo sync
  apu       Clone or switch <Prefix>_APU to main
  rpu       Clone or switch <Prefix>_RPU to main
  pl        Clone or switch <Prefix>_PL to main

Note:
  Every run also (re)generates an "openTmux" launcher in the workspace root.
  Run ./openTmux to open a tmux session with windows for yocto-build, APU,
  RPU, PL, and the yocto tftpboot directory.

Examples:
  setupWorkspace --product zudemo --workspace ~/work/zudemo all
  setupWorkspace --product kr260demo yocto apu
  setupWorkspace --product kr260demo pl rpu

Environment overrides:
  MANIFEST_REPO_URL  MANIFEST_BRANCH  MANIFEST_FILE
  YOCTO_DIR_NAME     APU_REPO_URL     RPU_REPO_URL    PL_REPO_URL
EOF
}

select_all() {
    DO_YOCTO=true
    DO_APU=true
    DO_RPU=true
    DO_PL=true
}

parse_arguments() {
    local selected=0

    while (($# > 0)); do
        case "$1" in
            --product)
                if (($# < 2)); then
                    printf 'Error: --product requires a product name.\n' >&2
                    exit 2
                fi
                MONUTCHEE_PRODUCT="$2"
                shift 2
                ;;

            --product=*)
                MONUTCHEE_PRODUCT="${1#*=}"
                shift
                ;;

            --workspace)
                if (($# < 2)); then
                    printf 'Error: --workspace requires a directory.\n' >&2
                    exit 2
                fi
                WORKSPACE_ROOT="$2"
                shift 2
                ;;

            --workspace=*)
                WORKSPACE_ROOT="${1#*=}"
                shift
                ;;

            all|ALL|All)
                select_all
                selected=1
                shift
                ;;

            yocto|YOCTO|Yocto)
                DO_YOCTO=true
                selected=1
                shift
                ;;

            apu|APU)
                DO_APU=true
                selected=1
                shift
                ;;

            rpu|RPU)
                DO_RPU=true
                selected=1
                shift
                ;;

            pl|PL)
                DO_PL=true
                selected=1
                shift
                ;;

            -h|--help)
                usage
                exit 0
                ;;

            *)
                printf 'Error: unknown option or component: %s\n\n' "$1" >&2
                usage >&2
                exit 2
                ;;
        esac
    done

    if ((selected == 0)); then
        usage
        exit 2
    fi
}

configure_product() {
    case "${MONUTCHEE_PRODUCT}" in
        zudemo|zuboard)
            MONUTCHEE_PRODUCT="zudemo"
            MANIFEST_FILE="${MANIFEST_FILE:-zudemo/zudemo.xml}"
            PROJECT_PREFIX="ZuBoardDemo"
            ;;

        kr260demo|kr260)
            MONUTCHEE_PRODUCT="kr260demo"
            MANIFEST_FILE="${MANIFEST_FILE:-kr260demo/kr260demo.xml}"
            PROJECT_PREFIX="KR260Demo"
            ;;

        "")
            printf 'Error: no product selected. Use --product zudemo or --product kr260demo.\n' >&2
            exit 2
            ;;

        *)
            printf 'Error: unsupported product: %s\n' "${MONUTCHEE_PRODUCT}" >&2
            exit 2
            ;;
    esac

    TMUX_SESSION="${MONUTCHEE_PRODUCT}"
    YOCTO_BUILD_DIR="build-${MONUTCHEE_PRODUCT}"
    APU_REPO_URL="${APU_REPO_URL:-git@github.com:lesterlo/${PROJECT_PREFIX}_APU.git}"
    RPU_REPO_URL="${RPU_REPO_URL:-git@github.com:lesterlo/${PROJECT_PREFIX}_RPU.git}"
    PL_REPO_URL="${PL_REPO_URL:-git@github.com:lesterlo/${PROJECT_PREFIX}_PL.git}"
}

create_runtime_directories() {
    mkdir -p -- \
        "${WORKSPACE_ROOT}/runtime-generated/vivado_SDT_out" \
        "${WORKSPACE_ROOT}/runtime-generated/bin_file"

    printf 'Runtime directories are ready:\n'
    printf '  %s\n' "${WORKSPACE_ROOT}/runtime-generated/vivado_SDT_out"
    printf '  %s\n' "${WORKSPACE_ROOT}/runtime-generated/bin_file"
}

create_tmux_launcher() {
    local launcher="${WORKSPACE_ROOT}/openTmux"

    # The product-specific values are expanded here into the launcher header;
    # the static body below is a quoted heredoc that references them at runtime.
    {
        printf '#!/usr/bin/env bash\n\n'
        printf 'set -Eeuo pipefail\n\n'
        printf '# Generated by setupWorkspace. Opens a "%s" tmux session with one\n' "${TMUX_SESSION}"
        printf '# window per component. Run it from anywhere in the workspace root.\n\n'
        printf 'SESSION=%q\n' "${TMUX_SESSION}"
        printf 'PROJECT_PREFIX=%q\n' "${PROJECT_PREFIX}"
        printf 'YOCTO_DIR=%q\n' "${YOCTO_DIR_NAME}"
        printf 'YOCTO_BUILD_DIR=%q\n\n' "${YOCTO_BUILD_DIR}"
        cat <<'BODY'
WORKSPACE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

if ! command -v tmux >/dev/null 2>&1; then
    printf 'Error: tmux was not found in PATH.\n' >&2
    exit 1
fi

# If the session already exists, just attach to (or switch to) it.
if tmux has-session -t "${SESSION}" 2>/dev/null; then
    printf 'Session %s already exists; attaching.\n' "${SESSION}"
    if [[ -n "${TMUX:-}" ]]; then
        exec tmux switch-client -t "${SESSION}"
    else
        exec tmux attach-session -t "${SESSION}"
    fi
fi

open_window() {
    # open_window <name> <directory>
    local name="$1"
    local dir="$2"

    if [[ ! -d "${dir}" ]]; then
        printf 'Warning: %s does not exist yet; opening %s in workspace root.\n' \
            "${dir}" "${name}" >&2
        dir="${WORKSPACE_ROOT}"
    fi

    if [[ -z "${SESSION_CREATED:-}" ]]; then
        tmux new-session -d -s "${SESSION}" -n "${name}" -c "${dir}"
        SESSION_CREATED=1
    else
        tmux new-window -t "${SESSION}:" -n "${name}" -c "${dir}"
    fi
}

open_window yocto "${WORKSPACE_ROOT}/${YOCTO_DIR}"

# Source the Yocto SDK environment in the yocto window.
if [[ -e "${WORKSPACE_ROOT}/${YOCTO_DIR}/setupSDK" ]]; then
    tmux send-keys -t "${SESSION}:yocto" 'source ./setupSDK' C-m
else
    printf 'Warning: %s/setupSDK not found; skipping source.\n' "${YOCTO_DIR}" >&2
fi

open_window apu  "${WORKSPACE_ROOT}/${PROJECT_PREFIX}_APU"
open_window rpu  "${WORKSPACE_ROOT}/${PROJECT_PREFIX}_RPU"
open_window pl   "${WORKSPACE_ROOT}/${PROJECT_PREFIX}_PL"
open_window tftp "${WORKSPACE_ROOT}/${YOCTO_DIR}/${YOCTO_BUILD_DIR}/export/tftpboot"

# Start on the first window.
tmux select-window -t "${SESSION}:yocto"

if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "${SESSION}"
else
    exec tmux attach-session -t "${SESSION}"
fi
BODY
    } >"${launcher}"

    chmod +x -- "${launcher}"

    printf 'tmux launcher is ready:\n'
    printf '  %s\n' "${launcher}"
}

clone_or_checkout_main() {
    local project_name="$1"
    local repo_url="$2"
    local destination="${WORKSPACE_ROOT}/${project_name}"

    if [[ ! -e "${destination}" ]]; then
        printf 'Cloning %s...\n' "${project_name}"

        if git clone "${repo_url}" "${destination}"; then
            printf 'Cloned %s on branch main.\n' "${project_name}"
            return 0
        fi

        printf 'Warning: failed to clone %s. The user may not have access.\n' \
            "${project_name}" >&2

        # Remove a partially created directory left by a failed clone.
        if [[ -e "${destination}" ]]; then
            rm -rf -- "${destination}"
        fi

        return 1
    fi

    if ! git -C "${destination}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        printf 'Error: destination exists but is not a Git repository:\n' >&2
        printf '  %s\n' "${destination}" >&2
        return 1
    fi

    if git -C "${destination}" show-ref --verify --quiet refs/heads/main; then
        git -C "${destination}" switch main || return 1
    elif git -C "${destination}" show-ref --verify --quiet refs/remotes/origin/main; then
        git -C "${destination}" switch --track origin/main || return 1
    else
        printf 'Error: %s has no local main or origin/main branch.\n' \
            "${project_name}" >&2
        return 1
    fi

    printf '%s is on branch main.\n' "${project_name}"
}

setup_yocto() {
    local yocto_dir="${WORKSPACE_ROOT}/${YOCTO_DIR_NAME}"

    if ! command -v repo >/dev/null 2>&1; then
        printf 'Error: repo command was not found in PATH.\n' >&2
        return 1
    fi

    if [[ -d "${yocto_dir}" && ! -d "${yocto_dir}/.repo" ]]; then
        if [[ -n "$(find "${yocto_dir}" -mindepth 1 -maxdepth 1 \
            ! -name '.mncos-product' -print -quit 2>/dev/null)" ]]; then

            printf 'Error: %s exists, is non-empty, and is not a repo workspace:\n' \
                "${YOCTO_DIR_NAME}" >&2
            printf '  %s\n' "${yocto_dir}" >&2
            return 1
        fi
    fi

    mkdir -p -- "${yocto_dir}"

    printf 'Initializing Yocto workspace:\n'
    printf '  product:             %s\n' "${MONUTCHEE_PRODUCT}"
    printf '  manifest repository: %s\n' "${MANIFEST_REPO_URL}"
    printf '  manifest branch:     %s\n' "${MANIFEST_BRANCH}"
    printf '  manifest file:       %s\n' "${MANIFEST_FILE}"
    printf '  destination:         %s\n' "${yocto_dir}"

    (
        cd "${yocto_dir}"

        repo init \
            -u "${MANIFEST_REPO_URL}" \
            -b "${MANIFEST_BRANCH}" \
            -m "${MANIFEST_FILE}" \
            || exit 1

        repo sync || exit 1
    ) || return 1

    # Record the product so `source ./setupSDK` works with no argument in every
    # new console.
    printf '%s\n' "${MONUTCHEE_PRODUCT}" > "${yocto_dir}/.mncos-product"
    printf 'Recorded product marker: %s (%s)\n' \
        "${MONUTCHEE_PRODUCT}" "${yocto_dir}/.mncos-product"

    printf 'Yocto workspace synchronized successfully.\n'
}

main() {
    local failures=0

    parse_arguments "$@"
    configure_product

    mkdir -p -- "${WORKSPACE_ROOT}"
    WORKSPACE_ROOT="$(cd -- "${WORKSPACE_ROOT}" && pwd -P)"

    printf 'Product:        %s\n' "${MONUTCHEE_PRODUCT}"
    printf 'Workspace root: %s\n\n' "${WORKSPACE_ROOT}"

    create_runtime_directories
    printf '\n'

    create_tmux_launcher
    printf '\n'

    if [[ "${DO_YOCTO}" == true ]]; then
        setup_yocto || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_APU}" == true ]]; then
        clone_or_checkout_main "${PROJECT_PREFIX}_APU" "${APU_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_RPU}" == true ]]; then
        clone_or_checkout_main "${PROJECT_PREFIX}_RPU" "${RPU_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if [[ "${DO_PL}" == true ]]; then
        clone_or_checkout_main "${PROJECT_PREFIX}_PL" "${PL_REPO_URL}" \
            || failures=$((failures + 1))
        printf '\n'
    fi

    if ((failures > 0)); then
        printf 'Workspace setup completed with %d failed component(s).\n' \
            "${failures}" >&2
        exit 1
    fi

    printf 'Workspace setup completed successfully.\n'
}

main "$@"
